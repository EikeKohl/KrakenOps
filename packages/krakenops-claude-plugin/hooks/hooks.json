{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:8787/v1/hooks/claude/post-tool-use",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:8787/v1/hooks/claude/session-start",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:8787/v1/hooks/claude/session-end",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
